CREATE OR REPLACE VIEW classificacao AS

WITH resultados AS (

    -- Jogos como mandante
    SELECT
        t.id_time,
        t.nome_time,
        t.id_grupo,

        1 AS jogos,

        CASE
            WHEN j.gols_time_casa > j.gols_time_visitante THEN 1
            ELSE 0
        END AS vitorias,

        CASE
            WHEN j.gols_time_casa = j.gols_time_visitante THEN 1
            ELSE 0
        END AS empates,

        CASE
            WHEN j.gols_time_casa < j.gols_time_visitante THEN 1
            ELSE 0
        END AS derrotas,

        j.gols_time_casa AS gols_pro,
        j.gols_time_visitante AS gols_contra,

        CASE
            WHEN j.gols_time_casa > j.gols_time_visitante THEN 3
            WHEN j.gols_time_casa = j.gols_time_visitante THEN 1
            ELSE 0
        END AS pontos

    FROM jogo j
    JOIN time t
        ON t.id_time = j.time_casa

    UNION ALL

    -- Jogos como visitante
    SELECT
        t.id_time,
        t.nome_time,
        t.id_grupo,

        1 AS jogos,

        CASE
            WHEN j.gols_time_visitante > j.gols_time_casa THEN 1
            ELSE 0
        END AS vitorias,

        CASE
            WHEN j.gols_time_visitante = j.gols_time_casa THEN 1
            ELSE 0
        END AS empates,

        CASE
            WHEN j.gols_time_visitante < j.gols_time_casa THEN 1
            ELSE 0
        END AS derrotas,

        j.gols_time_visitante AS gols_pro,
        j.gols_time_casa AS gols_contra,

        CASE
            WHEN j.gols_time_visitante > j.gols_time_casa THEN 3
            WHEN j.gols_time_visitante = j.gols_time_casa THEN 1
            ELSE 0
        END AS pontos

    FROM jogo j
    JOIN time t
        ON t.id_time = j.time_visitante
)

SELECT
    g.nome_grupo,
    r.id_time,
    r.nome_time,

    SUM(r.jogos) AS jogos,
    SUM(r.vitorias) AS vitorias,
    SUM(r.empates) AS empates,
    SUM(r.derrotas) AS derrotas,

    SUM(r.gols_pro) AS gols_pro,
    SUM(r.gols_contra) AS gols_contra,

    SUM(r.gols_pro) - SUM(r.gols_contra) AS saldo_gols,

    SUM(r.pontos) AS pontos

FROM resultados r
JOIN grupo g
    ON g.id_grupo = r.id_grupo

GROUP BY
    g.nome_grupo,
    r.id_time,
    r.nome_time

ORDER BY
    g.nome_grupo,
    pontos DESC,
    saldo_gols DESC,
    gols_pro DESC;
